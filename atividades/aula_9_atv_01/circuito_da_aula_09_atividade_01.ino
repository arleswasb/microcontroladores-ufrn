void setup() {
  // ==========================================================================
  // 1. CONFIGURAÇÃO DE PINOS (I/O)
  // ==========================================================================
  // Pino 9 → PB1 (OC1A - saída PWM do Timer1)
  DDRB |= (1 << PB1);


  // ==========================================================================
  // 2. CONFIGURAÇÃO DO ADC (Leitura do Potenciômetro)
  // ==========================================================================
  // ADMUX:
  // REFS0 = 1 → Referência AVcc (5V)
  // MUX = 0000 → Canal ADC0 (A0)
  ADMUX = (1 << REFS0);

  // ADCSRA:
  // ADEN → habilita ADC
  // ADPS2:0 → prescaler 128 (125kHz)
  ADCSRA = (1 << ADEN)  |
           (1 << ADPS2) |
           (1 << ADPS1) |
           (1 << ADPS0);


  // ==========================================================================
  // 3. CONFIGURAÇÃO DO TIMER1 (PWM - pino 9)
  // ==========================================================================
  // Modo: Fast PWM 8 bits

  // TCCR1A:
  // COM1A1 = 1 → ativa PWM no OC1A
  // WGM10 = 1 → modo PWM
  TCCR1A = (1 << COM1A1) | (1 << WGM10);

  // TCCR1B:
  // WGM12 = 1 → completa modo Fast PWM
  // CS11 = 1 → prescaler 8
  TCCR1B = (1 << WGM12) | (1 << CS11);


  // ==========================================================================
  // 4. INICIALIZAÇÃO DE SEGURANÇA
  // ==========================================================================
  EICRA = 0;
  EIMSK = 0;
}


/*
 * ============================================================================
 * Função: ADC_read
 * Descrição: Lê o valor do potenciômetro (A0)
 * Retorno: 0 a 1023
 * ============================================================================
 */
unsigned int leitura_ADC() {

  // Inicia conversão
  ADCSRA |= (1 << ADSC);

  // Aguarda finalizar
  while (ADCSRA & (1 << ADSC)) {
    __asm__("nop");
  }

  return ADC;
}


/*
 * ============================================================================
 * Função: PWM_write
 * Descrição: Atualiza o duty cycle do PWM (pino 9)
 * Parâmetro: 0 a 255
 * ============================================================================
 */
void reescrever_PWM(unsigned char valor) {

  // OCR1A controla o PWM
  OCR1A = valor;
}


// ==========================================================================
// LOOP PRINCIPAL (EXECUÇÃO CONTÍNUA EM TEMPO REAL)
// ==========================================================================
void loop() {

  // ==========================================================================
  // 1. LEITURA DO POTENCIÔMETRO
  // ==========================================================================
  unsigned int valorPot = leitura_ADC(); // 0–1023


  // ==========================================================================
  // 2. CONVERSÃO PARA PWM
  // ==========================================================================
  // Divide por 4 → escala 0–255
  unsigned char velocidade = valorPot >> 2;


  // ==========================================================================
  // 3. ATUALIZA O PWM (CONTROLE DO MOTOR)
  // ==========================================================================
  reescrever_PWM(velocidade);


  // ==========================================================================
  // OBS:
  // Sem delay → resposta imediata às mudanças do potenciômetro
  // ==========================================================================
}